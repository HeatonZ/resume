# Kimi（Moonshot）模型配置
MOONSHOT_API_KEY=your_kimi_api_key
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
MOONSHOT_MODEL=kimi-k2-0711-preview

# 智谱模型配置
ZHIPU_API_KEY=your_zhipu_api_key
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_MODEL=GLM-4.7-Flash

# 聊天模型路由（可选：kimi / zhipu）
CHAT_PROVIDER=kimi

# 服务监听配置
API_HOST=0.0.0.0
API_PORT=8000

# 允许跨域来源（生产环境建议填写你的前端域名，不要用 *）
ALLOWED_ORIGIN=*

# 防滥用与限流（基于 Deno KV）
# 是否开启限流保护
RATE_LIMIT_ENABLED=true
# KV 不可用时是否放行（false=保护优先，true=可用性优先）
RATE_LIMIT_FAIL_OPEN=false
# 短周期窗口（秒）
RATE_LIMIT_WINDOW_SECONDS=60
# 每个 IP 在短周期内允许的最大请求数
RATE_LIMIT_MAX_REQUESTS=80
# 每个 IP 每日允许的最大请求数
RATE_LIMIT_DAILY_MAX_REQUESTS=5000
# 在违规窗口内达到该次数后触发临时封禁
RATE_LIMIT_BLOCK_THRESHOLD=8
# 临时封禁时长（秒）
RATE_LIMIT_BLOCK_DURATION_SECONDS=600
# 违规统计窗口（秒）
RATE_LIMIT_VIOLATION_WINDOW_SECONDS=300
# 单次 message 最大字符数
CHAT_MAX_MESSAGE_CHARS=12000
# history 最大条数
CHAT_MAX_HISTORY_ITEMS=20
# 单次模型最大输出 token 上限
CHAT_MAX_OUTPUT_TOKENS=2048
# 流式会话最长持续时间（秒）
CHAT_STREAM_MAX_DURATION_SECONDS=90
# 首个 token 允许的最大延迟（毫秒）
CHAT_STREAM_FIRST_TOKEN_MAX_LATENCY_MS=5000
# 低于等于该 token 事件数将标记为退化流式
CHAT_STREAM_MIN_TOKEN_EVENTS=2

# 前端直连后端时可配置（不走 Vite 代理时使用）
VITE_API_BASE_URL=http://localhost:8000
